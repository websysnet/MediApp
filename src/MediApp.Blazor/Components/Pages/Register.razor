@page "/register"
@inject AuthService Auth
@inject NavigationManager Nav

<div class="register-container">
    <div class="card">
        <h3>Registrarse</h3>
        
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="alert alert-danger">@Error</div>
        }
        
        @if (RegistroExitoso)
        {
            <div class="alert alert-success">
                ¡Registro exitoso! <a href="/login">Iniciar sesión</a>
            </div>
        }

        <div class="form-group">
            <label>Nombre</label>
            <input type="text" @bind="Nombre" class="form-control" />
        </div>
        
        <div class="form-group">
            <label>Apellido</label>
            <input type="text" @bind="Apellido" class="form-control" />
        </div>
        
        <div class="form-group">
            <label>Email</label>
            <input type="email" @bind="Email" class="form-control" />
        </div>
        
        <div class="form-group">
            <label>Teléfono</label>
            <input type="tel" @bind="Telefono" class="form-control" />
        </div>
        
        <div class="form-group">
            <label>Contraseña</label>
            <input type="password" @bind="Password" class="form-control" />
        </div>
        
        <button class="btn btn-primary" @onclick="RegisterClick" disabled="@IsLoading">
            @(IsLoading ? "Registrando..." : "Registrarse")
        </button>
        
        <p class="mt-3">
            ¿Ya tienes cuenta? <a href="/login">Iniciar sesión</a>
        </p>
    </div>
</div>

@code {
    string Nombre = "";
    string Apellido = "";
    string Email = "";
    string? Telefono = "";
    string Password = "";
    string Error = "";
    bool IsLoading = false;
    bool RegistroExitoso = false;

    async Task RegisterClick()
    {
        if (string.IsNullOrEmpty(Nombre) || string.IsNullOrEmpty(Apellido) || 
            string.IsNullOrEmpty(Email) || string.IsNullOrEmpty(Password))
        {
            Error = "Por favor completa todos los campos obligatorios";
            return;
        }

        IsLoading = true;
        Error = "";

        try
        {
            await Auth.RegisterAsync(Email, Password, Nombre, Apellido, Telefono);
            RegistroExitoso = true;
        }
        catch (Exception ex)
        {
            Error = "Error al registrar. El email ya puede estar en uso.";
        }
        finally
        {
            IsLoading = false;
        }
    }
}

<style>
    .register-container {
        display: flex;
